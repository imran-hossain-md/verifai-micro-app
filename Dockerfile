# অফিশিয়াল লাইটওয়েট Deno ডকার ইমেজ ব্যবহার
FROM denoland/deno:alpine-1.42.1

# কন্টেইনারের ভেতর ওয়ার্কিং ডিরেক্টরি সেটআপ
WORKDIR /app

# কমপ্লায়েন্স সিকিউরিটি: রুট ইউজার বাদ দিয়ে 'deno' ইউজারে সুইচ করা
USER deno

# প্রজেক্টের ফাইলগুলো কন্টেইনারে কপি করা
COPY . .

# ডিপেন্ডেন্সিগুলো ক্যাশ (Cache) করে নেওয়া যাতে রানটাইম স্পিড সর্বোচ্চ হয়
RUN deno cache server.ts db.ts

# অ্যাপ্লিকেশন পোর্ট এক্সপোজ করা
EXPOSE 8000

# সার্ভার স্টার্ট করার ফাইনাল কমান্ড
CMD ["task", "start"]